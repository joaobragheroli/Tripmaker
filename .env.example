# ============================================================
# .env.example — Copie para .env e preencha os valores reais
# NUNCA commite o .env no repositório
# ============================================================

# Banco de dados (usado pelo PHP e pelo Node)
DB_HOST=localhost
DB_NAME=turismo
DB_USER=root
DB_PASS=

# OpenAI (usado por Pagina-ia/server.js)
OPENAI_API_KEY=COLOQUE_SUA_CHAVE_AQUI

# Google Maps (usado por Anuncie_Espaco/3.Local)
GOOGLE_MAPS_KEY=COLOQUE_SUA_CHAVE_AQUI

# Porta do servidor Node (opcional, padrão 3000)
PORT=3000
